# Python
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Environment
.env
!.env.example
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Model weights
models/**/*.pth
models/**/*.pt
!models/.gitkeep

# Logs
logs/

# Outputs / generated retrieval files
outputs/reference_feature_cache/
outputs/*.csv
outputs/hybrid_retrieval_*_partial.*
outputs/*_partial.json

# Generated visualizations
results/visualizations/*.png
results/visualizations/*.pdf

# Data
# Ignore everything in data by default
data/*

# Keep lightweight docs / metadata / manifests
!data/README_DATA.md
!data/manifests/
!data/manifests/queries.csv
!data/manifests/songs.csv
!data/manifests/splits.csv

!data/raw/
data/raw/*
!data/raw/metadata/
!data/raw/metadata/songs_metadata.csv

!data/hummed/
data/hummed/*
!data/hummed/metadata/
!data/hummed/metadata/hummed_metadata.csv

# Explicitly ignore heavy audio / generated folders
data/demucs_output/
data/hummed/recordings/
data/Humming Audio/
data/humming_queries/
data/Original Songs/
data/processed/
data/raw/original_songs/
data/song_references/

# Ignore spreadsheet exports unless you explicitly decide to keep them
data/*.xlsx
data/*.xls